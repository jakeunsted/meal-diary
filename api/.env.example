DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

DEV_DB_NAME=meal-diary-dev
DEV_DB_USER=postgres
DEV_DB_PASSWORD=postgres
# localhost when API runs on host; postgres when API runs in docker compose
DEV_DB_HOST=localhost
DEV_DB_PORT=5432

PROD_DB_NAME=
PROD_DB_USER=
PROD_DB_PASSWORD=
PROD_DB_HOST=
PROD_DB_PORT=

NODE_ENV=
PORT=

PROD_WEBHOOK_BASE_URL=
DEV_WEBHOOK_BASE_URL=

# PostHog project token (phc_*): analytics events + auth logs via OpenTelemetry
# @see https://posthog.com/docs/logs/installation/nodejs
POSTHOG_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
# Required only for GDPR person-deletion on account delete (separate from the
# ingestion key above). Without both, account deletion still works but the
# PostHog person/events are not erased (logged as a warning).
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# JWT Secrets
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Refresh token lifetime in days (default: 28). Rolling — extended on each use.
# REFRESH_TOKEN_TTL_DAYS=28

# Stripe Billing (test mode locally)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/profile?upgraded=1
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/plans
# Optional comma-separated extra redirect origins (e.g. https://dev.mealdiary.co.uk)
STRIPE_CHECKOUT_ALLOWED_ORIGINS=https://dev.mealdiary.co.uk
# Public site URL — also whitelisted for checkout redirects when set
ORIGIN=https://dev.mealdiary.co.uk
# Checkout/portal redirects are sent from the browser using window.location.origin
# so the user returns to the same host they started from (localhost vs 127.0.0.1).
# In non-production, localhost and *.mealdiary.co.uk origins are also allowed.
# RevenueCat (mobile IAP)
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_ENTITLEMENT_ID=family_plus
