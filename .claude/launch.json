{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "mobile-web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "3002"],
      "env": {
        "EXPO_PACKAGER_PROXY_URL": "https://dev-app.mealdiary.co.uk"
