{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=26.3.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --host 0.0.0.0",
    "dev-ios": "CAPACITOR_DEV=true npx cap sync && npx cap open ios",
    "dev-android": "CAPACITOR_DEV=true CAPACITOR_SERVER_URL=http://10.0.2.2:3000 npx cap sync && npx cap open android",
    "cap:sync:dev": "CAPACITOR_DEV=true npx cap sync",
    "cap:sync:dev:emulator": "CAPACITOR_SERVER_URL=http://10.0.2.2:3000 npx cap sync",
    "cap:sync:dev:device": "CAPACITOR_SERVER_URL=http://192.168.1.100:3000 npx cap sync",
    "cap:sync:prod": "npx cap sync",
    "cap:copy:dev": "CAPACITOR_DEV=true npx cap copy",
    "cap:copy:dev:emulator": "CAPACITOR_SERVER_URL=http://10.0.2.2:3000 npx cap copy",
    "cap:copy:dev:device": "CAPACITOR_SERVER_URL=http://192.168.1.100:3000 npx cap copy",
    "setup:icons": "node scripts/setup-app-icons.js",
    "build:android": "npm run build && npm run setup:icons && npx cap sync && cd android && ./gradlew assembleDebug",
    "build:android:release": "npm run build && npm run setup:icons && npx cap sync && cd android && ./gradlew assembleRelease",
    "install:android": "cd android && ./gradlew installDebug",
    "build:android:install": "npm run build:android && npm run install:android",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "start": "node .output/server/index.mjs",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:e2e:record": "cypress run --record"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capgo/capacitor-social-login": "^8.3.22",
    "@formkit/auto-animate": "^0.8.4",
    "@meal-diary/shared": "*",
    "@nuxtjs/dotenv": "^1.4.2",
    "@nuxtjs/i18n": "^9.5.6",
    "@opentelemetry/api-logs": "^0.219.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@pinia/nuxt": "^0.11.3",
    "@tailwindcss/vite": "^4.3.0",
    "@vesp/nuxt-fontawesome": "^1.2.1",
    "@vue-dnd-kit/core": "^2.4.6",
    "date-fns": "^4.1.0",
    "nuxt": "^3.21.8",
    "pinia": "^3.0.4",
    "posthog-js": "^1.388.1",
    "tailwindcss": "^4.3.0",
    "vue": "latest",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@nuxtjs/style-resources": "^1.2.2",
    "cypress": "^15.15.0",
    "daisyui": "^5.5.19",
    "oxc-parser": "^0.89.0",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.8"
  }
}
