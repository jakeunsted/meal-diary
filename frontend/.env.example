BASE_URL=http://localhost:3001
# Server-side Nuxt routes: http://api:3001 in docker compose; leave empty to use BASE_URL locally
API_INTERNAL_URL=
# Public site URL (e.g. https://dev.mealdiary.co.uk). Also added to Vite allowedHosts in dev.
ORIGIN=
SECRET_KEY=

# Server-only PostHog project token (phc_*) for auth log export via OpenTelemetry
# @see https://posthog.com/docs/logs/installation/nodejs
POSTHOG_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

POSTHOG_PUBLIC_KEY=

# Google Analytics 4. Optional and dormant by default: GA4 only loads when this
# is set, and only after the user grants analytics consent. Leave empty to
# disable GA4 entirely (PostHog remains the primary analytics tool).
GA_MEASUREMENT_ID=
# RevenueCat Capacitor SDK public keys
