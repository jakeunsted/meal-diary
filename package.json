{
  "name": "meal-diary",
  "private": true,
  "workspaces": [
    "api",
    "frontend",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=meal-diary-api --filter=nuxt-app",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e --filter=./frontend"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "engines": {
    "node": ">=26.3.0"
  },
  "packageManager": "npm@11.16.0"
}
