# Meal Diary API URL
# Android emulator: http://10.0.2.2:3001
# Physical device: http://<your-lan-ip>:3001
# Expo web (localhost): http://localhost:3001
# Expo web (nginx dev-app.mealdiary.co.uk): http://localhost:3001
EXPO_PUBLIC_API_URL=http://10.0.2.2:3001

# Public web app URL — used for invite links, legal pages, and plans
# Production: https://mealdiary.co.uk
# Dev (Expo web via nginx): https://dev-app.mealdiary.co.uk
EXPO_PUBLIC_WEB_URL=https://mealdiary.co.uk

# Optional: set when using nginx at dev-app.mealdiary.co.uk (see README)
# EXPO_PACKAGER_PROXY_URL=https://dev-app.mealdiary.co.uk

# Google Sign-In (optional — same Web OAuth client ID as API GOOGLE_CLIENT_ID)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Android OAuth client ID for com.mealdiary.app (recommended for native sign-in)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Optional: override Google OAuth redirect URI (must match Google Cloud Console exactly)
# EXPO_PUBLIC_GOOGLE_REDIRECT_URI=https://dev-app.mealdiary.co.uk
